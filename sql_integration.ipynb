   "source": [
    "import pandas as pd\n",
    "from sqlalchemy import create_engine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "39bf5f8c",
   "metadata": {},
   "outputs": [],
   "source": [
    "engine = create_engine(\"sqlite:///sales.db\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "8a965252",
   "metadata": {},
   "outputs": [],
   "source": [
    "query = \"\"\"\n",
    "SELECT Category,\n",
    "SUM(Sales) AS TotalSales\n",
    "FROM orders\n",
    "GROUP BY Category;\n",
    "\"\"\""
